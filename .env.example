# Copy to .env and fill in real values before running docker-compose up

# ── Shared across all services ────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
INTERNAL_API_KEY=change-me-to-another-long-random-string
CORS_ALLOWED_ORIGINS=http://localhost,https://yourdomain.com

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme

# ── Celery / Redis ────────────────────────────────────────────────────────────
# (URLs are wired in docker-compose using the redis service name — no change needed)

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=ServiceHub <noreply@yourdomain.com>

# ── Misc ──────────────────────────────────────────────────────────────────────
# Max providers notified when a new job is posted. Set to 0 for no limit.
JOB_NOTIFICATION_PROVIDER_LIMIT=0
